{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "types": []
  },
  "include": [
    "next-env.d.ts",
    ".types/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.tsx",
    "lib/**/*.ts"
  ],
  "exclude": ["node_modules", "_archive"]
}
